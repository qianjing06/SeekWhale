# ── 服务端口 ──
PORT=3000
NODE_ENV=development

# ── MongoDB ──
MONGO_URI=mongodb://127.0.0.1:27017/campus-collections

# ── Redis ──
REDIS_URL=redis://127.0.0.1:6379

# ── JWT ──
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=7d

# ── SMTP 邮箱验证码 ──
SMTP_HOST=smtp.nju.edu.cn
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@nju.edu.cn
SMTP_PASS=your-password

# ── 管理员邮箱（逗号分隔，4个） ──
ADMIN_EMAILS=admin1@smail.nju.edu.cn,admin2@smail.nju.edu.cn,admin3@nju.edu.cn,admin4@nju.edu.cn

# ── 上传文件存储路径 ──
UPLOAD_DIR=./uploads

# ── 高德地图 API Key ──
AMAP_API_KEY=your-amap-key

# ── 允许的邮箱域名 ──
ALLOWED_EMAIL_DOMAINS=smail.nju.edu.cn,nju.edu.cn
